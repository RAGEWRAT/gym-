# Public (exposed to browser)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_GYM_PHONE=+915122000000
# Optional: override default Open Graph image URL
# NEXT_PUBLIC_OG_IMAGE=https://yoursite.com/og.jpg

# Server-only (API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL="IronForge Gym <bookings@yourdomain.com>"
ADMIN_EMAIL=owner@yourdomain.com

# Optional: send booking confirmation to the user when email is provided
SEND_BOOKING_USER_EMAIL=false
